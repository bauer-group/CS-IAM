# =============================================================================
# Git Ignore Configuration
# =============================================================================

# Environment (Secrets)
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
.claude/
*.code-workspace
.history/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Temporary Files
*.tmp
*.temp
*.bak
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Terraform / OpenTofu
# State holds rendered secrets (OIDC client secrets) — never commit it.
*.tfstate
*.tfstate.*
.terraform/
crash.log
crash.*.log
# Real variable files carry credentials; only the *.example is tracked.
*.tfvars
*.tfvars.json
!*.tfvars.example
# The provider lock file is NOT committed: the provisioner runs a fresh
# `tofu init` each boot, and a platform-specific lock would cause hash
# mismatches across architectures.
.terraform.lock.hcl
**/.terraform.lock.hcl

# Zitadel machine key / generated credentials (never commit)
*.machinekey.json
admin.pat

# Key material / certificates — defense-in-depth (none are tracked today; this
# guards against an accidental future copy of a cert/key into the repo).
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12

# Deployment-private overrides & real-value snapshots (BAUER GROUP live config).
# The public templates ship generic example.com values; the real domains/hosts
# live here and are NEVER pushed. See .local/README.md.
.local/
docker-compose.*.local.yml
