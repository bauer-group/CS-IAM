# =============================================================================
# Root .dockerignore
# =============================================================================
# Applies to the images built with build-context = repo root:
#   - src/provisioner (bundles ./terraform)
#   - src/zitadel     (bakes ./config/zitadel/*.yaml)
# Keeps that context minimal and secret-free. The remaining images build from
# their own ./src/<svc> context with their own .dockerignore.
# =============================================================================

# VCS + CI
.git
.github
.gitignore
.gitattributes

# Secrets / local config — never bake into an image
**/.env
**/.env.*
!**/.env.example
*.tfstate
*.tfstate.*
**/.terraform/
*.tfvars
*.tfvars.json
!*.tfvars.example
*.machinekey.json
admin.pat

# Python / tooling caches
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/

# Docs + compose are not needed inside the provision image
docs/
*.md
docker-compose*.yml

# Other service sources are not part of the provisioner image
src/zitadel/
src/directory-sync/
src/database-backup/
scripts/
