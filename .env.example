# =============================================================================
# CS-IAM — Zitadel OIDC/IAM Stack — Environment Configuration
# =============================================================================
# Central, self-hosted OIDC/IAM provider on Zitadel with Entra federation,
# Infrastructure-as-Code provisioning (OpenTofu) and directory sync.
#
# /!\ BEFORE FIRST START — replace every value containing "CHANGE_ME" /!\
#
# One-shot, cross-platform (Windows / Linux / macOS):
#
#   python scripts/generate-env.py
#
# Creates .env from this template and fills every CHANGE_ME_* secret with a
# fresh random value. The CHANGE_ME placeholders also let `docker compose
# config` validate this file in CI.
#
# Deployment:
#   Development (local build): docker compose -f docker-compose.development.yml up -d --build
#   Traefik (HTTPS + LE):      docker compose -f docker-compose.traefik.yml     up -d
#   Coolify:                   configure env in dashboard -> docker-compose.coolify.yml
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

# Container / volume / network name prefix
STACK_NAME=iam

# Container timezone (e.g. Europe/Berlin, Etc/UTC)
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Configuration
# =============================================================================
# Development builds the custom images locally; production pulls the BAUER GROUP
# wrapper images from GHCR. The `zitadel` image is our wrapper too (it bakes in
# config/zitadel/*.yaml) — the upstream Zitadel version is pinned via the
# wrapper Dockerfile's BASE_ZITADEL_VERSION arg, so ZITADEL_VERSION selects the
# wrapper release tag (latest / stable / x.y.z), like the other sidecars.
ZITADEL_IMAGE=ghcr.io/bauer-group/cs-iam/zitadel
ZITADEL_VERSION=latest

POSTGRES_IMAGE=postgres
POSTGRES_VERSION=18-alpine

# Alpine base for the provisioner image + the machine-key prep step
ALPINE_IMAGE=alpine
ALPINE_VERSION=3.23

PROVISIONER_IMAGE=ghcr.io/bauer-group/cs-iam/provisioner
PROVISIONER_VERSION=latest

DIRECTORY_SYNC_IMAGE=ghcr.io/bauer-group/cs-iam/directory-sync
DIRECTORY_SYNC_VERSION=latest

DATABASE_BACKUP_IMAGE=ghcr.io/bauer-group/cs-iam/database-backup
DATABASE_BACKUP_VERSION=latest

# Login v2 hosted UI — two layers:
#   base  = EP-Zitadel fork (per-IdP brand logos)            -> LOGIN_BASE_*
#   image = CS-IAM branding overlay (src/login: favicon/icons) -> LOGIN_IMAGE
# Main logo + colors are runtime (Zitadel LabelPolicy / Assets), not baked.
LOGIN_IMAGE=ghcr.io/bauer-group/cs-iam/login
LOGIN_VERSION=latest
LOGIN_BASE_IMAGE=ghcr.io/bauer-group/ep-zitadel/zitadel-login
LOGIN_BASE_VERSION=latest

# Reverse proxy for the DEVELOPMENT stack only (single HTTPS origin for core +
# login). Prod uses your own external Traefik / Coolify proxy instead.
TRAEFIK_IMAGE=traefik
TRAEFIK_VERSION=v3.6.8
TRAEFIK_LOG_LEVEL=ERROR


# =============================================================================
# Hostnames & Routing
# =============================================================================

# Production public issuer (Traefik / Coolify variants)
IAM_HOSTNAME=id.bauer-group.com

# External Traefik network name
PROXY_NETWORK=EDGEPROXY

# Development issuer — the Docker service name `zitadel`, so the automation
# containers resolve it via Docker DNS and the issuer / JWT audience match.
# (A custom `*.localhost` name can't be used: it is forced to 127.0.0.1 inside
# every container, shadowing the network alias.) Dev runs over HTTPS: a Traefik
# `proxy` terminates TLS (self-signed) and serves ONE origin, path-routing
# /ui/v2/login to the login and everything else to the core. HTTPS is required —
# the Login v2 session cookie is `Secure`, so plain HTTP drops it mid-login.
# Browser access: add `127.0.0.1 zitadel` to your hosts file, open
# https://zitadel:8080/ui/console and accept the self-signed cert once.
IAM_DEV_HOSTNAME=zitadel
IAM_DEV_PORT=8080


# =============================================================================
# Zitadel Core Secrets
# =============================================================================

# Masterkey MUST be exactly 32 characters (encrypts secrets at rest). Keep a
# copy OUTSIDE the database backup — losing it makes encrypted data unrecoverable.
ZITADEL_MASTERKEY=CHANGE_ME_ZITADEL_MASTERKEY

# First admin (console login). Username/email are set in config/zitadel/steps.yaml
# (admin@bauer-group.com). Password must satisfy the complexity policy.
ZITADEL_ADMIN_PASSWORD=CHANGE_ME_ZITADEL_ADMIN_PASSWORD


# =============================================================================
# Database (PostgreSQL 18)
# =============================================================================

ZITADEL_DB_NAME=zitadel
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=CHANGE_ME_ZITADEL_DB_PASSWORD

# ── Storage I/O — tune for the disk the DB volume lives on ──────────────────
#   ┌─────────────────────────────┬───────────┬───────────┬───────────────┐
#   │ ENV Variable                │ SSD/NVMe  │ HDD 10k   │ HDD 7.2k RPM  │
#   │                             │ (default) │ RPM       │               │
#   ├─────────────────────────────┼───────────┼───────────┼───────────────┤
#   │ PG_RANDOM_PAGE_COST         │ 1.1       │ 2.0       │ 4.0           │
#   │ PG_EFFECTIVE_IO_CONCURRENCY │ 200       │ 4         │ 2             │
#   └─────────────────────────────┴───────────┴───────────┴───────────────┘
PG_RANDOM_PAGE_COST=1.1
PG_EFFECTIVE_IO_CONCURRENCY=200

# ── Memory — pick the column for your host RAM ──────────────────────────────
#   ┌─────────────────────────────┬─────────┬─────────┬─────────┬─────────┐
#   │ ENV Variable                │ 4 GB    │ 8 GB    │ 16 GB   │ 32 GB   │
#   ├─────────────────────────────┼─────────┼─────────┼─────────┼─────────┤
#   │ PG_SHARED_BUFFERS           │ 1GB     │ 2GB     │ 4GB     │ 8GB     │
#   │ PG_EFFECTIVE_CACHE_SIZE     │ 3GB     │ 6GB     │ 12GB    │ 24GB    │
#   │ PG_WORK_MEM                 │ 4MB     │ 8MB     │ 16MB    │ 32MB    │
#   │ PG_MAINTENANCE_WORK_MEM     │ 128MB   │ 256MB   │ 512MB   │ 1GB     │
#   └─────────────────────────────┴─────────┴─────────┴─────────┴─────────┘
# Defaults below = 8 GB host. The development compose defaults to the 4 GB column.
PG_SHARED_BUFFERS=2GB
PG_EFFECTIVE_CACHE_SIZE=6GB
PG_WORK_MEM=8MB
PG_MAINTENANCE_WORK_MEM=256MB

# ── WAL (Write-Ahead Log) — scale with host RAM ─────────────────────────────
#   ┌─────────────────────────────┬─────────┬─────────┬─────────┬─────────┐
#   │ ENV Variable                │ 4 GB    │ 8 GB    │ 16 GB   │ 32 GB   │
#   ├─────────────────────────────┼─────────┼─────────┼─────────┼─────────┤
#   │ PG_MAX_WAL_SIZE             │ 1GB     │ 2GB     │ 4GB     │ 8GB     │
#   │ PG_MIN_WAL_SIZE             │ 256MB   │ 512MB   │ 1GB     │ 2GB     │
#   └─────────────────────────────┴─────────┴─────────┴─────────┴─────────┘
PG_MAX_WAL_SIZE=2GB
PG_MIN_WAL_SIZE=512MB

# Max server connections (Zitadel pools internally; 100 suits most instances).
PG_MAX_CONNECTIONS=100


# =============================================================================
# Microsoft Entra ID / Graph
# =============================================================================
# App Registration with Application permissions (admin-consented):
#   User.Read.All, GroupMember.Read.All, ProfilePhoto.Read.All
# Leave blank to run a standalone stack without Entra federation/sync.
# This is the INTERNAL, single-tenant Entra (BAUER GROUP org login + Graph sync).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=


# =============================================================================
# External-org identity providers (customer login)
# =============================================================================
# Attached only to the "External Users" org. All optional — empty = skip.
# First-class (native templates).
# Entra multi-tenant (any MS / personal account):
EXTERNAL_AZURE_CLIENT_ID=
EXTERNAL_AZURE_CLIENT_SECRET=
EXTERNAL_GOOGLE_CLIENT_ID=
EXTERNAL_GOOGLE_CLIENT_SECRET=
# Any number of OAuth2 / OIDC providers via JSON maps (Facebook, WeChat, Naver,
# QQ, Weibo; LINE, KakaoTalk, …). Endpoint catalog: docs/identity-providers.md.
# These JSON blobs carry client secrets — keep this file at chmod 600.
EXTERNAL_OAUTH_IDPS=
EXTERNAL_OIDC_IDPS=


# =============================================================================
# Application OIDC Clients (Terraform)
# =============================================================================
# JSON array of OIDC apps consumed by terraform/applications.tf. Per entry:
# {name, redirect_uris[], post_logout_redirect_uris[]?, audience?}. `audience`
# picks the tier: "internal" (default → BAUER GROUP project, internal users) or
# "external" (External Apps project, granted to customers). Zitadel generates
# client_id/secret → read via `tofu output`. Full guide: docs/applications-oidc.md.
#   APP_REDIRECT_URIS=[{"name":"intranet","redirect_uris":["https://intranet.bauer-group.com/auth/callback"]},{"name":"partner-portal","audience":"external","redirect_uris":["https://partners.example.com/auth/oidc.callback"]}]
APP_REDIRECT_URIS=[]
# Self-contained DEMO (terraform/demo.tf): its own project "pDemo" with roles
# rUser/rManager/rAdministrator, the OIDC app "Demo", and a demo user
# (demo@bauer-group.com) granted rUser+rManager in pDemo ONLY — so it can use the
# Demo app and nothing else (cleanly isolated, production-safe). This password
# enables the whole demo (>=12 chars + complexity); MFA is set up on first login.
# Empty = no demo at all. Demo creds: `tofu output demo_app_client_id`.
DEMO_USER_PASSWORD=DemoLogin-2026!
# OIDC test client (dev `test` profile — tests/oidc-test-client). After the stack
# is up, set these to the Demo app's generated creds to run + validate the login:
#   cd terraform && tofu output demo_app_client_id   (+ -raw demo_app_client_secret)
OIDC_TEST_CLIENT_ID=
OIDC_TEST_CLIENT_SECRET=


# =============================================================================
# Login v2 UI (hosted login)
# =============================================================================
# Served by the `login` container at /ui/v2/login. Brand colors/logo/font come
# from the Zitadel LabelPolicy + Assets; these tune layout & feel.
# Login container internal port (path-routed by the proxy; not host-published).
IAM_LOGIN_PORT=3000
# Layout: side-by-side | top-to-bottom. `side-by-side` needs a background image
# on the second panel — but Next.js 16 bakes the public/ asset manifest at BUILD
# time, so a runtime-overlaid background (and favicon) 404s. Until branding moves
# into the image build, top-to-bottom is the clean, centred default.
LOGIN_THEME_LAYOUT=top-to-bottom
# Roundness: edgy | mid | full
LOGIN_THEME_ROUNDNESS=mid
# Spacing: regular | compact
LOGIN_THEME_SPACING=regular
# Appearance: flat | material
LOGIN_THEME_APPEARANCE=material
# Login-page background image. Empty = none. Only effective once the overlay
# assets are built into the image (see LOGIN_THEME_LAYOUT note).
LOGIN_BACKGROUND_IMAGE=
# On deploy, the one-shot `zitadel-brand` uploads the baked-in logo/icon/font
# (src/directory-sync/branding/) to the instance LabelPolicy + activates it.
# Set false to brand manually via Console -> Branding instead.
BRANDING_ENABLED=true


# =============================================================================
# Directory-Sync (Entra -> Zitadel)
# =============================================================================
SYNC_ENABLED=true
SYNC_PROFILES_INTERVAL=300       # seconds between Graph /users delta runs
SYNC_GROUPS_INTERVAL=600         # seconds between Graph /groups recompute runs
SYNC_ROLE_PREFIX=entra:          # namespace for synced roles/grants
SYNC_PROJECT_NAME=BAUER GROUP    # Zitadel project holding the role catalog
SYNC_WAIT_TIMEOUT=180
SYNC_LOG_LEVEL=INFO
SYNC_LOG_FORMAT=console


# =============================================================================
# Provisioner (OpenTofu)
# =============================================================================
PROVISIONER_WAIT_TIMEOUT=180


# =============================================================================
# Database Backup (--profile backup)
# =============================================================================
BACKUP_RETENTION_COUNT=14
BACKUP_SCHEDULE_ENABLED=true
BACKUP_SCHEDULE_MODE=cron
BACKUP_SCHEDULE_CRON=15 3 * * *
BACKUP_LOG_LEVEL=INFO

# Optional off-site S3 target (leave blank for local-only backups)
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_PREFIX=iam/

# Optional alerting
BACKUP_ALERT_ENABLED=false
BACKUP_ALERT_LEVEL=warnings
BACKUP_ALERT_CHANNELS=
BACKUP_ALERT_EMAIL=
BACKUP_TEAMS_WEBHOOK=


# =============================================================================
# SMTP (shared: Zitadel notifications + backup alerts)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@bauer-group.com
