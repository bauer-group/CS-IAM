# =============================================================================
# CS-IAM — Zitadel OIDC/IAM Stack — Environment Template
# =============================================================================
# 1. Generate secrets:   python scripts/generate-env.py
#    (replaces every CHANGE_ME_* below with a fresh secure value)
# 2. Set IAM_HOSTNAME + the AZURE_* values for your tenant.
# 3. Start:              docker compose -f docker-compose.development.yml up -d
#
# CHANGE_ME_* placeholders are intentionally invalid so a half-configured
# stack fails fast. Never commit the generated .env.
# =============================================================================

# ── Stack ────────────────────────────────────────────────────────────────────
STACK_NAME=iam
TIME_ZONE=Etc/UTC

# ── Images ───────────────────────────────────────────────────────────────────
# Development uses the upstream Zitadel image (guaranteed to exist). For
# production switch ZITADEL_IMAGE to the BAUER GROUP wrapper once published:
#   ZITADEL_IMAGE=ghcr.io/bauer-group/cs-iam/zitadel  /  ZITADEL_VERSION=latest
ZITADEL_IMAGE=ghcr.io/zitadel/zitadel
ZITADEL_VERSION=v4.15.0
POSTGRES_IMAGE=postgres
POSTGRES_VERSION=18-alpine
PROVISION_IMAGE=ghcr.io/bauer-group/cs-iam/zitadel-provision
PROVISION_VERSION=latest
SYNC_IMAGE=ghcr.io/bauer-group/cs-iam/zitadel-sync
SYNC_VERSION=latest
BACKUP_IMAGE=ghcr.io/bauer-group/cs-iam/zitadel-backup
BACKUP_VERSION=latest

# ── Hostnames / routing ──────────────────────────────────────────────────────
# Production public issuer (Traefik/Coolify variants):
IAM_HOSTNAME=id.bauer-group.com
# Traefik external network name:
PROXY_NETWORK=EDGEPROXY
# Development only (browser + containers both resolve this):
IAM_DEV_HOSTNAME=zitadel.localhost
IAM_DEV_PORT=8080

# ── Zitadel core secrets ─────────────────────────────────────────────────────
# Masterkey MUST be exactly 32 characters (encrypts secrets at rest).
ZITADEL_MASTERKEY=CHANGE_ME_ZITADEL_MASTERKEY
# First admin (console login). Username/email are set in config/zitadel/steps.yaml
# (admin@bauer-group.com). Password must satisfy the complexity policy.
ZITADEL_ADMIN_PASSWORD=CHANGE_ME_ZITADEL_ADMIN_PASSWORD

# ── Database (PostgreSQL 18) ─────────────────────────────────────────────────
ZITADEL_DB_NAME=zitadel
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=CHANGE_ME_ZITADEL_DB_PASSWORD
# Tuning (baseline = small host; scale shared_buffers/effective_cache_size up
# to ~25% / ~75% of host RAM on larger machines).
PG_MAX_CONNECTIONS=100
PG_SHARED_BUFFERS=512MB
PG_WORK_MEM=4MB
PG_EFFECTIVE_CACHE_SIZE=1536MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_MAX_WAL_SIZE=1GB
PG_MIN_WAL_SIZE=256MB

# ── Microsoft Entra ID / Graph ───────────────────────────────────────────────
# App Registration with Application permissions:
#   User.Read.All, GroupMember.Read.All, ProfilePhoto.Read.All (admin-consented)
# Leave blank to run a standalone stack without Entra federation/sync.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Application OIDC clients (Terraform) ─────────────────────────────────────
# JSON array of {name, redirect_uris[]} consumed by terraform/applications.tf.
# Generated client_id/secret are read back via `tofu output`.
# Example:
#   APP_REDIRECT_URIS=[{"name":"outline","redirect_uris":["https://wiki.bauer-group.com/auth/oidc.callback"]}]
APP_REDIRECT_URIS=[]

# ── Directory-sync (zitadel-sync) ────────────────────────────────────────────
SYNC_ENABLED=true
SYNC_PROFILES_INTERVAL=300       # seconds between Graph /users delta runs
SYNC_GROUPS_INTERVAL=600         # seconds between Graph /groups delta runs
SYNC_ROLE_PREFIX=entra:          # namespace for synced roles/grants
SYNC_PROJECT_NAME=BAUER GROUP    # Zitadel project that holds the role catalog
SYNC_WAIT_TIMEOUT=180
SYNC_LOG_LEVEL=INFO
SYNC_LOG_FORMAT=console

# ── Provisioning (zitadel-provision) ─────────────────────────────────────────
PROVISION_WAIT_TIMEOUT=180

# ── Backup (zitadel-backup, --profile backup) ────────────────────────────────
BACKUP_RETENTION_COUNT=14
BACKUP_SCHEDULE_ENABLED=true
BACKUP_SCHEDULE_MODE=cron
BACKUP_SCHEDULE_CRON=15 3 * * *
BACKUP_LOG_LEVEL=INFO
# Optional off-site S3 target (leave blank for local-only backups):
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_PREFIX=iam/
# Optional alerting:
BACKUP_ALERT_ENABLED=false
BACKUP_ALERT_LEVEL=warnings
BACKUP_ALERT_CHANNELS=
BACKUP_ALERT_EMAIL=
BACKUP_TEAMS_WEBHOOK=

# ── SMTP (shared: Zitadel notifications + backup alerts) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@bauer-group.com
